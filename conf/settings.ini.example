#smtp_recipient:    example-test2@gmx.de
#imap_username:     example-test2@gmx.de
#imap_password:     xxxxx

[description-example-test-gmail-com]
imap_hostname:     imap.gmail.com
imap_username:     example-test@gmail.com
imap_password:     xxxxx
